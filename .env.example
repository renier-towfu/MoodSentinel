# ============================================================
# MoodSentinel — Environment Variables
# Copy to .env and fill in your values. Never commit .env.
# ============================================================

PORT=8000
ENVIRONMENT=development

MOODSENTINEL_CHECKPOINT_DIR=checkpoints
MOODSENTINEL_MAX_COMMENTS=200
MOODSENTINEL_MIN_COMMENTS=3

# Facebook credentials (optional — only needed for private posts)
FB_EMAIL=your_email@example.com
FB_PASSWORD=your_password
